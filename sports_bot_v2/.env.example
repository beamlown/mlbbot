# --- dugout_dash (port 8900) ---
DUGOUT_DASH_PORT=8900
DUGOUT_DASH_HOST=0.0.0.0
# {slug} = team display name lowercase_underscored, e.g. "colorado_rockies"
TAZZ_BASE_URL=https://tazztv.io/?league=MLB&name={slug}
# Which team's broadcast: "home" (default) or "away"
TAZZ_TEAM_SIDE=home
# Skip iframe attempt and go straight to deep-link button
TAZZ_FORCE_LINK=0
TAZZ_IFRAME_TIMEOUT_MS=3000
# Upper cap on mark_update events per slug per second
DUGOUT_MARK_UPDATE_HZ=5
# Hall-of-Fame cache TTL (seconds)
DUGOUT_HOF_CACHE_TTL=60
# Set to 1 to enable /api/events/test_publish (dev only)
DUGOUT_DASH_DEV=0

# ── Sport selection ─────────────────────────────────────────────────────────
# "baseball" or "basketball"
SPORT=baseball

# ── Paths ───────────────────────────────────────────────────────────────────
DB_PATH=trades_sports.db
STATE_PATH=runtime/state.json
OB_SNAPSHOTS_DIR=runtime/ob_snapshots
DISCOVERY_CACHE_PATH=runtime/last_discovery.json

# ── Loop behavior ───────────────────────────────────────────────────────────
LOOP_SECONDS=30
DISCOVERY_REFRESH_LOOPS=10
LOG_LEVEL=INFO

# ── Orderbook filters ───────────────────────────────────────────────────────
MAX_SPREAD=0.04
MIN_DEPTH_TOP5_USD=500
ENTRY_IMBALANCE_MAX=0.60
MAX_ENTRY_PRICE=0.99

# ── Risk / position sizing ──────────────────────────────────────────────────
PAPER_POSITION_SIZE_USD=50.0
PAPER_FEE_PCT=0.02
PAPER_SLIPPAGE_PCT=0.005
MAX_CONCURRENT_TRADES=3
MAX_TRADES_PER_MARKET=1

# ── Exit thresholds ─────────────────────────────────────────────────────────
AUTO_TAKE_PROFIT_PCT=0.85
AUTO_STOP_LOSS_PCT=0.20
NEAR_RESOLUTION_PRICE=0.92
TRAILING_STOP_ACTIVATE_PCT=0.15
TRAILING_STOP_DRAWDOWN_PCT=0.20
TIME_EXIT_BUFFER_SECONDS=300

# ── Stop-loss cluster protection ─────────────────────────────────────────────
SL_CLUSTER_TRIGGER=3
SL_COOLDOWN_LOOPS=5

# ── Market validity ─────────────────────────────────────────────────────────
ENTRY_EVENT_MAX_AGE_MINUTES=300
ENTRY_FAIL_CLOSED_ON_MISSING_METADATA=true

# ── Adaptive mode ───────────────────────────────────────────────────────────
MODE_DWELL_TRADES=10
ADAPTIVE_UPSHIFT_SCORE=0.65
ADAPTIVE_DOWNSHIFT_SCORE=0.35

# ── Signal weights (OB microstructure) ─────────────────────────────────────
SIG_W_MOMENTUM=0.28
SIG_W_MEAN_REVERT=0.17
SIG_W_IMBALANCE=0.25
SIG_MEAN_REVERT_EXTREME_THRESHOLD=0.4
MOMENTUM_MIN_SAMPLES=4
MIN_CONFIDENCE=0.58

# ── Signal weights: game context by market type ─────────────────────────────
# MLB defaults (baseball)
SIG_W_GAME_MONEYLINE=0.30
SIG_W_GAME_SPREAD=0.35
SIG_W_GAME_TOTAL=0.45

# For basketball, override:
# SIG_W_GAME_MONEYLINE=0.25
# SIG_W_GAME_SPREAD=0.40
# SIG_W_GAME_TOTAL=0.40
# MIN_CONFIDENCE=0.55

# ── MLB-specific thresholds ─────────────────────────────────────────────────
SCORING_RUN_THRESHOLD_MLB=3
LATE_INNING_BLOCK=7
PITCHER_FATIGUE_PITCH_COUNT=90
SPREAD_MIN_OUTS_MLB=9
TOTAL_MIN_OUTS_MLB=9
SPREAD_COVER_NORM_MLB=3.0
TOTAL_NORM_MLB=2.0

# MLB Stats API (free, no auth required)
MLB_STATS_API_BASE=https://statsapi.mlb.com/api/v1

# ── NCAAB-specific thresholds (basketball) ──────────────────────────────────
SCORING_RUN_THRESHOLD=8
FINAL_MINUTES_BLOCK_SECONDS=180
SPREAD_MIN_ELAPSED_SEC=300
TOTAL_MIN_ELAPSED_SEC=300
SPREAD_COVER_NORM=7.0
TOTAL_NORM=8.0

# ── Polymarket integration (Stair A) ───────────────────────────────────────
# Toggles the batched midpoints+prices OB-scan path. Off = legacy parallel /book.
USE_BATCH_PRICES=false
# CLOB host override (only change for staging/testing)
CLOB_HOST=https://clob.polymarket.com
# Polygon chain id (137 = mainnet)
POLYGON_CHAIN_ID=137
# On-disk tick-size cache path (relative to sports_bot_v2/)
TICK_SIZE_CACHE_PATH=runtime/tick_sizes.json
# Retry tuning for polymarket_client
POLYMARKET_CLIENT_RETRIES=3
POLYMARKET_CLIENT_BACKOFF_MS=500

# ── Polymarket execution (Stair C) — DO NOT MODIFY WITHOUT READING ALL NOTES ───
# PHASE gates whether paper_exec routes to live_exec at all.
#   paper = local book-walk only (current behavior; no orders ever sent)
#   live  = route through live_exec.place_order (STILL guarded by kill-switch)
# Default 'paper'. NEVER change to 'live' until you have also:
#   1. Set LIVE_TRADING_KILL_SWITCH=false
#   2. Set SIGNER=private_key
#   3. Set PRIVATE_KEY=<funded wallet key>
#   4. Verified balance with account_sync (Stair D)
#   5. Run 10+ $1-size test orders and reconciled results
PHASE=paper

# Second independent gate on live order placement. MUST be true for paper mode.
# Setting false enables real order submission IF PHASE=live AND signer.is_ready().
# FAIL-SAFE PARSE: only the strings 'false', '0', 'no', 'off' lift the switch;
# any other value (including typos or empty) engages it. Treat this as the
# emergency brake: flipping it back to true at any time while live immediately
# halts all new order placement (requires process restart to take effect).
LIVE_TRADING_KILL_SWITCH=true

# Signer selection:
#   dummy       = DummySigner, returns fake signatures. is_ready()=False so
#                 live_exec refuses to submit even with both other gates open.
#   private_key = PrivateKeySigner. Requires PRIVATE_KEY env. sign_order() is
#                 intentionally NotImplementedError this cycle (deferred to a
#                 future Stair C production task that adds wallet-funding
#                 verification and a live-CLOB kill-switch test).
# Default 'dummy'. Any other value raises ValueError at get_signer() call.
SIGNER=dummy

# Hex-encoded Polygon EOA private key. ONLY required when SIGNER=private_key.
# Leave commented out for paper operation. Store in .env.secrets (gitignored),
# NOT in .env. Never commit a funded key.
# PRIVATE_KEY=0x...

# ── Polymarket user stream (Stair B) ──────────────────────────────────────────
# Enable the ws/user subscription to receive TRADE and ORDER events for our
# own orders. Off by default. Also auto-enabled when PHASE=live.
#
# SAFETY: this is the ONLY way to open a ws/user connection. Default 'false'
# means no auth derivation attempt, no API-key file written, no websocket
# opened. Safe for paper operation.
#
# When enabled (and signer is real), the bot derives API creds from the
# wallet on first run and caches them to runtime/polymarket_creds.json
# (gitignored). Subsequent runs reuse the cache.
#
# Dummy-signer mode: enabling this flag yields a one-line warning at startup
# ("user_stream: not starting (DummySigner cannot derive...)") and then no-op.
# Paper bot behavior is unaffected.
USER_STREAM_MIRROR=false

# ── Polymarket account sync (Stair D) ─────────────────────────────────────────
# Low-balance warning threshold. fetch_balance() logs WARN when wallet USDC
# balance falls below this value. Default is 50.0 (2× the PAPER_POSITION_SIZE_USD
# default). Tune to your own bankroll policy.
MIN_BALANCE_WARN_USD=50.0

# Optional: explicitly enable/disable account_sync at boot. Default behavior
# (no env var set) is driven by signer availability — paper mode (DummySigner)
# no-ops, live mode reconciles. If you want to disable in live mode too (not
# recommended), set ACCOUNT_SYNC_ENABLED=false.
ACCOUNT_SYNC_ENABLED=true
