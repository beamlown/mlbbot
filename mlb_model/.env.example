# MLB Model — environment variables
# Copy to .env and fill in values

# ── Data pipeline ──────────────────────────────────────────────────────────────
# Seasons to train on (comma-separated)
TRAIN_SEASONS=2018,2019,2020,2021,2022
TUNE_SEASONS=2023
CALIBRATE_SEASONS=2024
TEST_SEASONS=2025

# Where to store raw downloads
RAW_DATA_DIR=data/raw

# Where to store processed feature parquets
FEATURE_DIR=data/features

# ── Model artifacts ───────────────────────────────────────────────────────────
ARTIFACT_DIR=artifacts

# ── Live inference ────────────────────────────────────────────────────────────
# ESPN APIs are public (no key needed)
GAME_STATE_CACHE_TTL=15        # seconds
SCOREBOARD_CACHE_TTL=10

# Polymarket CLOB API (same as sports_bot_v2 .env)
# CLOB_API_URL=https://clob.polymarket.com
# GAMMA_API_URL=https://gamma-api.polymarket.com
# PK=<your private key>

# Sharp odds (same key as sports_bot_v2)
# ODDS_API_KEY=<your key>
# ODDS_CACHE_TTL_SECONDS=90

# ── Execution guard ───────────────────────────────────────────────────────────
MIN_EDGE_THRESHOLD=0.05        # minimum edge to recommend a trade
STRONG_EDGE_THRESHOLD=0.08     # strong signal tier
FEE_COST=0.02                  # Polymarket fee fraction
SLIPPAGE_COST=0.003            # base slippage estimate
MAX_SPREAD=0.035               # max YES spread
MIN_TOUCH_DEPTH_USD=200        # min thin-side depth
LIVE_WARMUP_SECONDS=90         # block entries for this long after game goes live
GAME_STATE_MAX_AGE_SEC=15      # stale game state threshold
BOOK_MAX_AGE_SEC=5             # stale book threshold

# ── Integration / shadow mode ─────────────────────────────────────────────────
SHADOW_LOG_PATH=logs/shadow_recommendations.jsonl
PHASE=shadow                   # shadow | advisory | merged
